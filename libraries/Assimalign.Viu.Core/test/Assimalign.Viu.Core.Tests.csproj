<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>$(TargetFrameworkForLibraries)</TargetFramework>
    <IsPackable>false</IsPackable>
  </PropertyGroup>
  <ItemGroup>
    <!-- The compiled-render end-to-end proof ([V01.01.03.22]) nests its own project under test/ so the
         generator's transitive Assimalign.Viu.Syntax.Templates reference (which links copies of Shared's
         PatchFlags/SlotFlags) never enters THIS project's compile closure and collide with Shared.dll.
         Keep its sources out of this project's implicit globs. -->
    <Compile Remove="Assimalign.Viu.Core.CompiledRenderTests/**" />
    <None Remove="Assimalign.Viu.Core.CompiledRenderTests/**" />
  </ItemGroup>
  <ItemGroup>
    <ViuPackageReference Include="Microsoft.NET.Test.Sdk" />
    <ViuPackageReference Include="xunit" />
    <ViuPackageReference Include="xunit.runner.visualstudio" />
    <ViuPackageReference Include="Shouldly" />
  </ItemGroup>
  <ItemGroup>
    <ViuProjectReference Include="Assimalign.Viu.Core" />
    <ViuProjectReference Include="Assimalign.Viu.Testing" />
    <ViuProjectReference Include="Assimalign.Viu.Shared" />
  </ItemGroup>
  <!-- Run the [Reactive] source generator over this project's test classes so the behavioral tests
       (the merged Reactivity/GeneratedReactiveObjectTests) consume real generated output. -->
  <ItemGroup>
    <ViuAnalyzerReference Include="Assimalign.Viu.Core.Generators" />
  </ItemGroup>
</Project>
