<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <!-- Deviates from the repo build-system rule (libraries use $(TargetFrameworkForLibraries) = net10.0)
         per the syntax-cluster architectural steer: like its sibling parsers, the CSS parser runs INSIDE
         Roslyn generator hosts (scoped CSS [V01.01.06.04], CSS Modules [V01.01.06.06], and embedded
         style tooling), which are netstandard2.0 analyzer hosts. It therefore targets the analyzer TFM
         alias — the same central property the other Assimalign.Vue.Syntax.* projects use — never a
         hardcoded string. Its net10.0 test project references it normally. -->
    <TargetFramework>$(TargetFrameworkForAnalyzers)</TargetFramework>
    <!-- Source-generator-hosted code must target the stable analyzer surface: opt out of the repo-wide
         preview-features switch (see build/Targets/Build.TargetFramework.props) so no
         [RequiresPreviewFeatures] leaks into the netstandard2.0 assembly. Mirrors the sibling parsers. -->
    <EnablePreviewFeatures>false</EnablePreviewFeatures>
    <!-- IsAotCompatible is intentionally not set here: the AOT analyzers require net8.0+, so the central
         libraries targets clear the inherited IsAotCompatible=true for this netstandard2.0 TFM. The
         assembly is consumed at build time by generators, never shipped into the WASM app. -->
  </PropertyGroup>
  <ItemGroup>
    <!-- The shared base ([V01.01.05.09]): Position, SourceLocation, SyntaxList, SyntaxNode, the parser
         pipeline, and the Diagnostic surface live in Assimalign.Vue.Syntax; CssSyntaxNode and
         CssSyntaxParser derive from them. -->
    <VuecsProjectReference Include="Assimalign.Vue.Syntax" />
  </ItemGroup>
  <ItemGroup>
    <!-- Linked netstandard2.0 shims ([V01.01.05.09]): IsExternalInit and the required-member attributes
         are authored once in Assimalign.Vue.Syntax and <Compile Include>'d here (still internal) because
         an internal shim in a referenced assembly is not visible to this compilation — each netstandard2.0
         assembly needs its own copy to light up `init`/`record`/`required`. -->
    <Compile Include="..\..\Assimalign.Vue.Syntax\src\Shims\IsExternalInit.cs" Link="Shims\IsExternalInit.cs" />
    <Compile Include="..\..\Assimalign.Vue.Syntax\src\Shims\RequiredMemberShims.cs" Link="Shims\RequiredMemberShims.cs" />
  </ItemGroup>
</Project>
