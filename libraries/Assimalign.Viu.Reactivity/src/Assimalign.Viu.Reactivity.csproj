<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>$(TargetFrameworkForLibraries)</TargetFramework>
    <IsAotCompatible>true</IsAotCompatible>
  </PropertyGroup>
  <!-- The [Reactive] source generator ships inside this package (analyzers/dotnet/cs) so consumers
       that add a package/project reference to Assimalign.Viu.Reactivity get [Reactive] support
       without referencing the generator directly. -->
  <ItemGroup>
    <ViuAnalyzerReference Include="Assimalign.Viu.Reactivity.Generators" />
  </ItemGroup>
</Project>
