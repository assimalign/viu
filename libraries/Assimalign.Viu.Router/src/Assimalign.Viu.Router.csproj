<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>$(TargetFrameworkForLibraries)</TargetFramework>
    <IsAotCompatible>true</IsAotCompatible>
    <!-- Required by the [JSImport]/[JSExport] interop source generator (SYSLIB1074) for the
         browser history edge (Internal/JavaScriptBrowserHistoryInterop, BrowserHistoryInteropDispatch);
         the memory history and the whole matcher stay interop-free. -->
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>
  <!-- RouterView/RouterLink consume the component model and reactivity (issue #72 boundary: the
       Router area may reference Runtime Core, Reactivity, and Shared). The matcher and history code
       itself stays framework-free; only the components/Router facade touch these references. -->
  <ItemGroup>
    <ViuProjectReference Include="Assimalign.Viu.RuntimeCore" />
    <ViuProjectReference Include="Assimalign.Viu.Reactivity" />
  </ItemGroup>
</Project>
