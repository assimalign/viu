<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>$(TargetFrameworkForLibraries)</TargetFramework>
    <IsAotCompatible>true</IsAotCompatible>
    <!-- Required by the [JSImport]/[JSExport] interop source generator (SYSLIB1074) for the
         browser history edge (Internal/JavaScriptBrowserHistoryInterop, BrowserHistoryInteropDispatch);
         the memory history and the whole matcher stay interop-free. -->
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>
  <!-- RouterView/RouterLink consume the unified component model and the Router facade owns one
       shallow reactive reference. The matcher and history implementation remain framework-free;
       Router does not depend on a renderer or host application implementation. -->
  <ItemGroup>
    <ViuProjectReference Include="Assimalign.Viu.Components" />
    <ViuProjectReference Include="Assimalign.Viu.Reactivity" />
  </ItemGroup>
</Project>
