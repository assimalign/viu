<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>$(TargetFrameworkForLibraries)</TargetFramework>
    <IsPackable>false</IsPackable>
  </PropertyGroup>
  <ItemGroup>
    <ViuPackageReference Include="Microsoft.NET.Test.Sdk" />
    <ViuPackageReference Include="xunit" />
    <ViuPackageReference Include="xunit.runner.visualstudio" />
    <ViuPackageReference Include="Shouldly" />
  </ItemGroup>
  <ItemGroup>
    <ViuProjectReference Include="Assimalign.Viu.ServerRenderer" />
    <ViuProjectReference Include="Assimalign.Viu.Core" />
    <!-- Round-trip tests parse real SSR output and hydrate it through Testing's live and immutable
         snapshot readers, pinning the cross-package marker and adoption contract. -->
    <ViuProjectReference Include="Assimalign.Viu.Testing" />
  </ItemGroup>
</Project>
