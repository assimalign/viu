<Project>

    <!-- Analyzer & Build Dependencies -->
    <ItemGroup>
        <_ViuPackage Include="Microsoft.CodeAnalysis.Analyzers" Version="5.3.0" />
        <_ViuPackage Include="Microsoft.CodeAnalysis.CSharp" Version="5.3.0" />
        <_ViuPackage Include="Microsoft.CodeAnalysis.CSharp.Workspaces" Version="5.0.0">
            <PrivateAssets>all</PrivateAssets>
        </_ViuPackage>
        <_ViuPackage Include="Microsoft.CodeAnalysis.Workspaces.MSBuild" Version="5.0.0">
            <PrivateAssets>all</PrivateAssets>
        </_ViuPackage>
        <_ViuPackage Include="Microsoft.Build" Version="18.7.1">
            <PrivateAssets>all</PrivateAssets>
            <!-- MSBuild supplies the task-host runtime; retain only compile assets. -->
            <ExcludeAssets>runtime</ExcludeAssets>
        </_ViuPackage>
        <_ViuPackage Include="Microsoft.Build.Framework" Version="18.7.1">
            <PrivateAssets>all</PrivateAssets>
            <ExcludeAssets>runtime</ExcludeAssets>
        </_ViuPackage>
        <_ViuPackage Include="Microsoft.Build.Utilities.Core" Version="18.7.1">
            <PrivateAssets>all</PrivateAssets>
            <ExcludeAssets>runtime</ExcludeAssets>
        </_ViuPackage>
        <_ViuPackage Include="Microsoft.Build.Locator" Version="1.11.2" />
        <_ViuPackage Include="Microsoft.CodeAnalysis.CSharp.SourceGenerators.Testing" Version="1.1.4" />
        <!-- The Visual Studio client remains a thin out-of-process adapter. Keep both packages on
             the same release line because the build package generates the extension manifest for
             the corresponding VisualStudio.Extensibility SDK surface. -->
        <_ViuPackage Include="Microsoft.VisualStudio.Extensibility.Sdk" Version="17.14.40608" />
        <_ViuPackage Include="Microsoft.VisualStudio.Extensibility.Build" Version="17.14.40608" />
    </ItemGroup>

    <!-- Benchmark Dependencies -->
    <ItemGroup>
        <!-- BenchmarkDotNet hosts the DOM-free micro/meso benchmarks ([V01.01.11.04], #88): reactivity
             track/trigger and renderer diff/patch on the in-memory test adapter, on CoreCLR. It never
             ships and is not trimmed/AOT'd (bench project, like the tests). Restored from dotnet-public. -->
        <_ViuPackage Include="BenchmarkDotNet" Version="0.15.8" />
    </ItemGroup>

    <!-- XUnit Test Dependencies-->
    <ItemGroup>
        <_ViuPackage Include="Shouldly" Version="4.3.0" />
        <_ViuPackage Include="xunit" Version="2.9.3" />
        <_ViuPackage Include="Microsoft.NET.Test.Sdk" Version="18.6.0" />
        <_ViuPackage Include="xunit.runner.visualstudio" Version="3.1.5"
            IncludeAssets="runtime; build; native; contentfiles; analyzers; buildtransitive"
            PrivateAssets="all" />
        <_ViuPackage Include="coverlet.collector" Version="10.0.1">
            <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
            <PrivateAssets>all</PrivateAssets>
        </_ViuPackage>
    </ItemGroup>

    <!-- #region: Package Reference Update -->
    <ItemGroup>
        <!--
            Metadata declared on the central catalog does not flow through an Update automatically.
            Copy every package-control field used above while preserving project-local metadata when
            the catalog leaves that field unspecified.
        -->
        <ViuPackageReference Update="@(_ViuPackage)" Version="%(_ViuPackage.Version)">
            <PrivateAssets Condition="'%(_ViuPackage.PrivateAssets)' != ''">%(_ViuPackage.PrivateAssets)</PrivateAssets>
            <IncludeAssets Condition="'%(_ViuPackage.IncludeAssets)' != ''">%(_ViuPackage.IncludeAssets)</IncludeAssets>
            <ExcludeAssets Condition="'%(_ViuPackage.ExcludeAssets)' != ''">%(_ViuPackage.ExcludeAssets)</ExcludeAssets>
        </ViuPackageReference>
        <PackageReference Include="@(ViuPackageReference)" />
        <ViuPackageReference Remove="@(ViuPackageReference)" />
    </ItemGroup>
    <!-- #endregion -->
</Project>
