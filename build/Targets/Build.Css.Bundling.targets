<Project>
  <!--
    Static-web-asset CSS bundling for .viu single-file components ([V01.01.12.12]) — the MSBuild half that
    completes the RS1035 deferral recorded in libraries/Assimalign.Viu.Syntax.Css/docs/DESIGN.md (a source
    generator emits C#, not content files; this task does the I/O a generator cannot).

    Imported LATE (via build/Build.targets -> Directory.Build.targets), after the consuming csproj has set
    $(ViuUseSingleFileComponents) — the same seam the generator's build props/targets rely on, so the
    property is observable here (it is NOT in the early build/*.props).

    Flow, gated on $(ViuBundleSingleFileComponentCss) (defaults to $(ViuUseSingleFileComponents)):
      1. _ViuResolveSingleFileComponentCssConfiguration — derive the intermediate bundle path/name.
      2. _ViuBundleSingleFileComponentCss — Inputs/Outputs-incremental; runs the ViuBundleCss task,
         which re-runs the shared deterministic core over the same **/*.viu inputs and writes the bundle
         (only when its content actually changed).
      3. ResolveViuSingleFileComponentCssAssets — registers the bundle as a Computed StaticWebAsset (the
         same DefineStaticWebAssets path Blazor scoped CSS uses for <App>.styles.css), so build/publish copy
         and fingerprint it and the dev host serves it. Runs just before ResolveStaticWebAssetsInputs.

    FINGERPRINTING ([V01.01.12.12.03]): when the SDK's static-web-asset fingerprinting is on (the WASM /
    Blazor default, $(StaticWebAssetFingerprintingEnabled) == 'true') the bundle's logical URL carries the
    #[.{fingerprint}] token, via the same DefineStaticWebAssets path Blazor's scoped-CSS application bundle
    uses ($(PackageId)#[.{fingerprint}]?.styles.css). The SDK computes the token from a SHA-256 hash of the
    bundle's CONTENT (no timestamps), so the fingerprint is deterministic: identical styles across rebuilds
    keep the same hash, changed styles get a new one — the browser cache-busts only on real change. We use
    the OPTIONAL form ('?'): the SDK emits BOTH a fingerprinted route (WebApp.<hash>.viu.css, served
    immutable) and the stable plain route (WebApp.viu.css). Each fingerprinted endpoint carries a `label`
    equal to the plain route, plus the content hash and integrity — that endpoint is the resolution mechanism
    an ASP.NET Core host, a CDN, or the future auto-injection ([V01.01.12.12.01]) uses to serve the immutable
    URL. In a statically hosted WASM app the plain-named physical file is the one that ships, so the demo's
    explicit <link> keeps resolving.

    Why not the '!' (required) form the WASM SDK uses for main#[.{fingerprint}]!.js: the host-page
    #[.{fingerprint}] placeholder resolution (OverrideHtmlAssetPlaceholders) is scoped to JS ES modules /
    the import map; it does NOT rewrite a CSS <link> href to the hashed name (it strips the token to the
    plain name). '!' would therefore ship ONLY the hashed physical file while the demo's static <link>
    resolved to the plain name — a 404. '?' keeps the plain file serving AND registers the fingerprinted
    identity/endpoint, which is exactly what this task owns; delivering the hashed URL into the host page is
    [V01.01.12.12.01]'s job (build-time link injection off the endpoint this task registers).

    LOAD THE BUNDLE: nothing to author — the LINK INJECTION section at the bottom of this file
    ([V01.01.12.12.01]) splices <link rel="stylesheet" href="<AssemblyName>.viu.css" /> into the host page
    (wwwroot/index.html) automatically. That href is the bundle's stable logical URL — the plain-named
    physical file a static host serves, and (with the '?' fingerprinted endpoint registered here) the same
    asset an ASP.NET Core host serves immutably via its hashed route (a class library's bundle is at
    _content/<PackageId>/<AssemblyName>.viu.css). Injection is compression-safe (it re-registers the host page
    before the SDK's compression pipeline; see the LINK INJECTION comment) and idempotent (a hand-authored
    <link>, or $(ViuInjectSingleFileComponentCssLink)=false, opts out).
  -->

  <PropertyGroup>
    <!-- Master switch: bundle the .viu @style CSS into a static web asset. Defaults ON wherever single-file
         component generation is on, so the same one property opts a project into both. Set to false to keep
         .viu compilation but skip physical bundling. Evaluated here (late) so $(ViuUseSingleFileComponents)
         — set in the consuming csproj — is already known. -->
    <ViuBundleSingleFileComponentCss Condition="'$(ViuBundleSingleFileComponentCss)' == '' and '$(ViuUseSingleFileComponents)' == 'true'">true</ViuBundleSingleFileComponentCss>
    <ViuBundleSingleFileComponentCss Condition="'$(ViuBundleSingleFileComponentCss)' == ''">false</ViuBundleSingleFileComponentCss>

    <!-- The in-repo dogfood path to the built ViuBundleCss task assembly. Packaged consumers override this
         to the task shipped in the package. Configuration-aware so a Debug or Release build resolves its
         matching task build. -->
    <ViuBundleCssTaskAssembly Condition="'$(ViuBundleCssTaskAssembly)' == ''">$(ViuOutputPathForSdk)\$(NETCoreSdkVersion)\sdks\Assimalign.Viu.Sdk\Tasks\Assimalign.Viu.Sdk.Tasks.dll</ViuBundleCssTaskAssembly>

    <!-- LINK INJECTION master switch ([V01.01.12.12.01], #167): auto-inject the bundle's <link
         rel="stylesheet"> into the WASM host page (wwwroot/index.html) so a consuming app needs no
         hand-authored link tag. Defaults ON wherever bundling is on. Set to false to keep bundling but author
         the <link> by hand (the injector is idempotent, so a hand-authored link is also a working opt-out —
         it simply suppresses injection). The ViuInjectCssBundleLink task ships in the same Sdk.Tasks
         assembly as ViuBundleCss, so it resolves through $(ViuBundleCssTaskAssembly) with no extra wiring. -->
    <ViuInjectSingleFileComponentCssLink Condition="'$(ViuInjectSingleFileComponentCssLink)' == '' and '$(ViuBundleSingleFileComponentCss)' == 'true'">true</ViuInjectSingleFileComponentCssLink>
    <ViuInjectSingleFileComponentCssLink Condition="'$(ViuInjectSingleFileComponentCssLink)' == ''">false</ViuInjectSingleFileComponentCssLink>
  </PropertyGroup>

  <!-- The task lives in sdks/Assimalign.Viu.Sdk/Tasks; it re-runs the shared Tooling.Css core
       OUTSIDE the analyzer sandbox so it may write files. Declared whenever bundling is on — NOT gated on
       Exists($(ViuBundleCssTaskAssembly)). A UsingTask condition is evaluated at static import time, which
       for the in-repo dogfood path can precede the Sdk.Tasks build (the assembly is loaded through
       AssemblyFile, not a ProjectReference, so nothing ordered its build first). Gating on Exists there
       raced the build: the target could run after the DLL appeared while the UsingTask, evaluated earlier
       against a not-yet-built DLL, was never declared — MSB4036 "task not found". UsingTask resolves its
       AssemblyFile lazily (only when the task is first invoked), and the invoking target keeps its own
       Exists gate, so declaring it unconditionally is safe when the task is genuinely absent. The in-repo
       build-order edge below guarantees the DLL exists by the time the target runs. -->
  <UsingTask TaskName="Assimalign.Viu.Sdk.Tasks.ViuBundleCss"
             AssemblyFile="$(ViuBundleCssTaskAssembly)"
             Condition="'$(ViuBundleSingleFileComponentCss)' == 'true'" />

  <!-- The host-page <link> injector ([V01.01.12.12.01]) ships in the same Sdk.Tasks assembly. Declared
       unconditionally-of-Exists for the same reason ViuBundleCss is (see above): a UsingTask AssemblyFile is
       resolved lazily on first invocation, and the invoking targets keep their own Exists gate, so the
       in-repo build-order edge is what guarantees the DLL is present by the time the injector runs. -->
  <UsingTask TaskName="Assimalign.Viu.Sdk.Tasks.ViuInjectCssBundleLink"
             AssemblyFile="$(ViuBundleCssTaskAssembly)"
             Condition="'$(ViuInjectSingleFileComponentCssLink)' == 'true'" />

  <!-- In-repo dogfooding build-order edge ([V01.01.12.12.03]): a consuming project loads ViuBundleCss via
       <UsingTask AssemblyFile=...>, which is NOT a project reference, so the solution/dependency scheduler
       has no reason to build Sdk.Tasks before this project. A WASM sample (the first in-repo consumer of
       CSS bundling) therefore raced the task build and failed with MSB4036 on a clean build. This
       reference-output-free edge forces Sdk.Tasks to build first. Guarded to the in-repo path
       ($(ViuRepositoryDirectory) set); the packaged SDK ships the task inside the package (Sdk.Common.props
       presets $(ViuBundleCssTaskAssembly) to the packaged copy), so an external consumer never takes this
       edge and never sees a raw ProjectReference.
       Deviates from the repo build-system rule (no raw <ProjectReference>) per design decision: a build-order
       edge the ViuProjectReference transform cannot express — a netstandard2.0 task referenced with
       ReferenceOutputAssembly=false and UndefineProperties to cross the app's TFM/RID boundary, mirroring
       frameworks/Assimalign.Viu.App.Refs. -->
  <ItemGroup Condition="'$(ViuBundleSingleFileComponentCss)' == 'true' and '$(ViuRepositoryDirectory)' != '' and Exists('$(ViuRepositoryDirectory)sdks\Assimalign.Viu.Sdk\Tasks\Assimalign.Viu.Sdk.Tasks.csproj')">
    <ProjectReference Include="$(ViuRepositoryDirectory)sdks\Assimalign.Viu.Sdk\Tasks\Assimalign.Viu.Sdk.Tasks.csproj"
                      ReferenceOutputAssembly="false"
                      Private="false"
                      PrivateAssets="all"
                      UndefineProperties="TargetFramework;RuntimeIdentifier" />
  </ItemGroup>

  <Target Name="_ViuResolveSingleFileComponentCssConfiguration"
          Condition="'$(ViuBundleSingleFileComponentCss)' == 'true'"
          DependsOnTargets="ResolveStaticWebAssetsConfiguration">
    <PropertyGroup>
      <!-- The bundle's stable logical name split into base (no extension) and extension primitives, so the
           plain and fingerprinted relative paths derive from the same pieces and can never drift. Override a
           primitive to rename the bundle; a consumer overriding the composed $(ViuSingleFileComponentCssBundleName)
           or $(ViuSingleFileComponentCssBundleFingerprintExpression) directly should override both to keep
           the two routes in lock-step. -->
      <ViuSingleFileComponentCssBundleBaseName Condition="'$(ViuSingleFileComponentCssBundleBaseName)' == ''">$(PackageId)</ViuSingleFileComponentCssBundleBaseName>
      <ViuSingleFileComponentCssBundleExtension Condition="'$(ViuSingleFileComponentCssBundleExtension)' == ''">.viu.css</ViuSingleFileComponentCssBundleExtension>
      <!-- Stable, unfingerprinted logical file name (e.g. WebApp.viu.css). Also the physical file name under
           obj/…/viu/ — the on-disk bundle is never renamed; only the served URL gains the content hash. -->
      <ViuSingleFileComponentCssBundleName Condition="'$(ViuSingleFileComponentCssBundleName)' == ''">$(ViuSingleFileComponentCssBundleBaseName)$(ViuSingleFileComponentCssBundleExtension)</ViuSingleFileComponentCssBundleName>
      <!-- Fingerprinted logical file name pattern (e.g. WebApp#[.{fingerprint}]?.viu.css). DefineStaticWebAssets
           substitutes a SHA-256 content hash into the #[.{fingerprint}] token. The trailing '?' makes the
           fingerprint OPTIONAL — the same token Blazor's scoped-CSS application bundle uses
           ($(PackageId)#[.{fingerprint}]?.styles.css): the SDK emits BOTH a fingerprinted route
           (WebApp.<hash>.viu.css, immutable) and the stable plain route (WebApp.viu.css), and in a statically
           hosted WASM app the plain-named physical file is what ships, so the demo's <link> keeps resolving.
           The fingerprinted route/endpoint (carrying `label` = the plain route + the content hash + integrity)
           is what an ASP.NET Core host, a CDN, or the future auto-injection ([V01.01.12.12.01]) resolves for
           cache-busting. ('!' — required — would instead ship ONLY the hashed physical file; the WASM SDK's
           #[.{fingerprint}] host-page placeholder resolution is ES-module-only and does not rewrite a CSS
           <link> href to the hashed name, so '!' would 404 the demo's static link.) -->
      <ViuSingleFileComponentCssBundleFingerprintExpression Condition="'$(ViuSingleFileComponentCssBundleFingerprintExpression)' == ''">$(ViuSingleFileComponentCssBundleBaseName)#[.{fingerprint}]?$(ViuSingleFileComponentCssBundleExtension)</ViuSingleFileComponentCssBundleFingerprintExpression>
      <_ViuCssBundleContentRoot>$([System.IO.Path]::GetFullPath('$(IntermediateOutputPath)viu\'))</_ViuCssBundleContentRoot>
      <_ViuCssBundlePath>$(_ViuCssBundleContentRoot)$(ViuSingleFileComponentCssBundleName)</_ViuCssBundlePath>
    </PropertyGroup>
  </Target>

  <!-- Run the task. Inputs/Outputs make a no-input-change rebuild a no-op at the MSBuild level; the task
       ALSO content-compares and skips the write when the bytes are unchanged, so the timestamp only moves on
       a real change. Both layers satisfy the incremental acceptance criterion. -->
  <Target Name="_ViuBundleSingleFileComponentCss"
          Condition="'$(ViuBundleSingleFileComponentCss)' == 'true' and Exists('$(ViuBundleCssTaskAssembly)')"
          DependsOnTargets="_ViuResolveSingleFileComponentCssConfiguration"
          Inputs="@(ViuSingleFileComponent)"
          Outputs="$(_ViuCssBundlePath)">
    <ViuBundleCss SingleFileComponents="@(ViuSingleFileComponent)"
                    ProjectDirectory="$(ProjectDir)"
                    BundleOutputPath="$(_ViuCssBundlePath)">
      <Output TaskParameter="BundlePath" PropertyName="_ViuCssBundleWrittenPath" />
      <Output TaskParameter="BundleWritten" PropertyName="_ViuCssBundleWasWritten" />
    </ViuBundleCss>
    <ItemGroup>
      <FileWrites Include="$(_ViuCssBundlePath)" Condition="Exists('$(_ViuCssBundlePath)')" />
    </ItemGroup>
  </Target>

  <!-- Register the bundle as a Computed static web asset (mirrors Microsoft.NET.Sdk.StaticWebAssets.ScopedCss
       ResolveBundledCssAssets). BeforeTargets ResolveStaticWebAssetsInputs so the asset joins @(StaticWebAsset)
       before the manifest is generated — robust against import ordering. Always runs (not Inputs/Outputs-gated)
       so the asset is registered on every build/publish even when the file itself was unchanged; only
       registers when the bundle exists. -->
  <Target Name="ResolveViuSingleFileComponentCssAssets"
          Condition="'$(ViuBundleSingleFileComponentCss)' == 'true' and Exists('$(ViuBundleCssTaskAssembly)')"
          BeforeTargets="ResolveStaticWebAssetsInputs"
          DependsOnTargets="_ViuBundleSingleFileComponentCss">
    <ItemGroup Condition="Exists('$(_ViuCssBundlePath)')">
      <_ViuCssBundleStaticWebAssetCandidate Include="$(_ViuCssBundlePath)">
        <!-- Fingerprint the served URL when the SDK's static-web-asset fingerprinting is on (the WASM/Blazor
             default). DefineStaticWebAssets replaces the #[.{fingerprint}] token with a deterministic content
             hash and (for the '?' optional form) registers both the fingerprinted and the stable plain route.
             Falls back to the plain name when fingerprinting is disabled. Same DefineStaticWebAssets path as
             Microsoft.NET.Sdk.StaticWebAssets.ScopedCss ResolveBundledCssAssets. -->
        <RelativePath Condition="'$(StaticWebAssetFingerprintingEnabled)' == 'true'">$(ViuSingleFileComponentCssBundleFingerprintExpression)</RelativePath>
        <RelativePath Condition="'$(StaticWebAssetFingerprintingEnabled)' != 'true'">$(ViuSingleFileComponentCssBundleName)</RelativePath>
      </_ViuCssBundleStaticWebAssetCandidate>
    </ItemGroup>

    <DefineStaticWebAssets Condition="'@(_ViuCssBundleStaticWebAssetCandidate)' != ''"
                           CandidateAssets="@(_ViuCssBundleStaticWebAssetCandidate)"
                           SourceType="Computed"
                           SourceId="$(PackageId)"
                           ContentRoot="$(_ViuCssBundleContentRoot)"
                           BasePath="$(StaticWebAssetBasePath)"
                           AssetKind="All"
                           AssetMode="CurrentProject"
                           AssetRole="Primary"
                           CopyToOutputDirectory="Never"
                           CopyToPublishDirectory="PreserveNewest">
      <Output TaskParameter="Assets" ItemName="_ViuCssBundleStaticWebAsset" />
    </DefineStaticWebAssets>

    <DefineStaticWebAssetEndpoints Condition="'@(_ViuCssBundleStaticWebAsset)' != ''"
                                   CandidateAssets="@(_ViuCssBundleStaticWebAsset)"
                                   ContentTypeMappings="@(StaticWebAssetContentTypeMapping)">
      <Output TaskParameter="Endpoints" ItemName="_ViuCssBundleStaticWebAssetEndpoint" />
    </DefineStaticWebAssetEndpoints>

    <ItemGroup>
      <StaticWebAsset Include="@(_ViuCssBundleStaticWebAsset)" />
      <StaticWebAssetEndpoint Include="@(_ViuCssBundleStaticWebAssetEndpoint)" />
    </ItemGroup>
  </Target>

  <!--
    ============================================================================================
    HOST-PAGE <link> INJECTION ([V01.01.12.12.01], #167)
    ============================================================================================
    Splice <link rel="stylesheet" href="<PackageId>.viu.css"> into the WASM host page so a consuming app
    needs no hand-authored link tag, WITHOUT desyncing the SDK's compression negotiation.

    WHY THE EARLIER ATTEMPT BROKE COMPRESSION, AND HOW THIS AVOIDS IT.
    The SDK computes gzip/brotli variants from an asset's CONTENT and binds each compressed variant to its
    primary asset's identity + integrity (Microsoft.NET.Sdk.StaticWebAssets.Compression.targets:
    ResolveCompressedAssets enumerates @(StaticWebAsset); ApplyCompressionNegotiation keys the .gz/.br
    endpoints to the primary's integrity). Rewriting the host page's static web asset AFTER that negotiation
    ran orphans its compressed variants — the negotiation endpoint still points at the pre-rewrite integrity,
    the .gz/.br carry pre-rewrite bytes, and the mismatched pair is dropped: compressed variants stop being
    served. That is exactly the failure #167 records from the first (in-place) attempt.

    The SDK's OWN host-page rewriter (OverrideHtmlAssetPlaceholders, which resolves main#[.{fingerprint}].js)
    avoids this by rewriting the page into an intermediate copy, RE-REGISTERING the asset+endpoint with fresh
    integrity, and doing so BEFORE compression — it explicitly injects its rewrite target into
    Resolve*CompressedStaticWebAssets*DependsOn. We mirror that contract exactly: write a copy with the link
    spliced in, re-register (RemoveMetadata Integrity;Fingerprint so DefineStaticWebAssets recomputes them),
    and run BEFORE Resolve{Build,Publish}CompressedStaticWebAssetsConfiguration so compression derives from
    the injected content. The CSS bundle asset itself is never touched here, so its gzip/brotli endpoints
    (registered in ResolveViuSingleFileComponentCssAssets, well before compression) are wholly undisturbed.

    WHY THIS RE-USES THE SDK REWRITE RATHER THAN RACES IT: when OverrideHtmlAssetPlaceholders is on, the
    injector DependsOn the SDK's rewrite target so it runs strictly AFTER it (reading the placeholder-resolved
    page and adding the link on top); when it is off, the dependency is empty and the injector transforms the
    discovered page directly. Either way the injector is the LAST host-page transform before compression.

    WHY THE PLAIN ROUTE, NOT THE FINGERPRINTED ONE: the bundle registers with the '?' optional fingerprint
    ([V01.01.12.12.03]), so a standalone `dotnet publish` ships only the plain physical file
    (<PackageId>.viu.css) — the fingerprinted route resolves to that same file ONLY through the endpoint
    manifest (a manifest-aware host: `dotnet run`, ASP.NET Core, a configured CDN). A statically hosted
    published WASM app has no such middleware, so a hashed href would 404. The plain route works everywhere
    and still revalidates via the endpoint's ETag/integrity; the fingerprinted endpoint remains registered for
    hosted scenarios. See libraries/Assimalign.Viu.Tooling.Css/docs/DESIGN.md. Override the href with
    $(ViuSingleFileComponentCssBundleLinkHref) for a manifest-aware deployment that wants the immutable URL.
  -->

  <Target Name="_ViuResolveSingleFileComponentCssLinkConfiguration"
          Condition="'$(ViuInjectSingleFileComponentCssLink)' == 'true'"
          DependsOnTargets="_ViuResolveSingleFileComponentCssConfiguration">
    <PropertyGroup>
      <!-- The href written into the host page. Defaults to the bundle's stable plain route (the file a static
           host serves); a manifest-aware deployment can point it at the fingerprinted route for immutable
           caching. -->
      <ViuSingleFileComponentCssBundleLinkHref Condition="'$(ViuSingleFileComponentCssBundleLinkHref)' == ''">$(ViuSingleFileComponentCssBundleName)</ViuSingleFileComponentCssBundleLinkHref>
      <!-- Intermediate roots for the injected host-page copies. The physical page under wwwroot/ is never
           edited in place — each build/publish copy is written here and re-registered from it. -->
      <_ViuCssLinkBuildContentRoot>$([System.IO.Path]::GetFullPath('$(IntermediateOutputPath)viu\htmllink\build\'))</_ViuCssLinkBuildContentRoot>
      <_ViuCssLinkPublishContentRoot>$([System.IO.Path]::GetFullPath('$(IntermediateOutputPath)viu\htmllink\publish\'))</_ViuCssLinkPublishContentRoot>
      <!-- Order the injector strictly after the SDK's host-page rewrite when that rewrite is active, so the
           link is added to the placeholder-resolved page (and never lost to a stale rewrite snapshot). Empty
           when OverrideHtmlAssetPlaceholders is off, so the injector then transforms the discovered page. -->
      <_ViuCssLinkBuildRewriteDependency Condition="'$(OverrideHtmlAssetPlaceholders)' == 'true'">ResolveHtmlAssetPlaceholdersBuildStaticWebAssets</_ViuCssLinkBuildRewriteDependency>
      <_ViuCssLinkPublishRewriteDependency Condition="'$(OverrideHtmlAssetPlaceholders)' == 'true'">ResolveHtmlAssetPlaceholdersPublishStaticWebAssets</_ViuCssLinkPublishRewriteDependency>
    </PropertyGroup>
  </Target>

  <!-- BUILD: inject into the build-kind host page before build compression enumerates assets. Mirrors the
       SDK's ResolveHtmlAssetPlaceholdersBuildStaticWebAssets (AssetKind != Publish → recompute as Build). -->
  <Target Name="_ViuInjectSingleFileComponentCssLinkBuild"
          Condition="'$(ViuInjectSingleFileComponentCssLink)' == 'true' and Exists('$(ViuBundleCssTaskAssembly)')"
          BeforeTargets="ResolveBuildCompressedStaticWebAssetsConfiguration"
          DependsOnTargets="_ViuResolveSingleFileComponentCssLinkConfiguration;$(_ViuCssLinkBuildRewriteDependency)">
    <ItemGroup Condition="Exists('$(_ViuCssBundlePath)')">
      <_ViuCssLinkHostPageBuild Include="@(StaticWebAsset)"
                                Condition="'%(Extension)' == '.html' and '%(AssetKind)' != 'Publish'" />
    </ItemGroup>

    <!-- Write the copy under the physical FILE NAME (index.html), NOT %(RelativePath): a fingerprinted asset's
         RelativePath is the URL template (e.g. index#[.{fingerprint}]?.html) and is not a legal file path. The
         original RelativePath is preserved on the re-registered candidate below, so the served route (and its
         optional fingerprint) is unchanged; only the physical intermediate file is named plainly. -->
    <ViuInjectCssBundleLink Condition="'@(_ViuCssLinkHostPageBuild)' != ''"
                            HostPagePath="%(_ViuCssLinkHostPageBuild.FullPath)"
                            OutputPath="$(_ViuCssLinkBuildContentRoot)%(_ViuCssLinkHostPageBuild.FileName)%(_ViuCssLinkHostPageBuild.Extension)"
                            LinkHref="$(ViuSingleFileComponentCssBundleLinkHref)"
                            BundleFileName="$(ViuSingleFileComponentCssBundleName)" />

    <ItemGroup Condition="'@(_ViuCssLinkHostPageBuild)' != ''">
      <!-- Re-point the candidates at the injected copies (identity = the written file) and drop the
           computed-per-content metadata so DefineStaticWebAssets recomputes integrity/fingerprint from the new
           content and the preserved RelativePath token. OriginalItemSpec MUST be reset to the injected file:
           it is the path the SDK's ResolveCompressedAssets reads as the compression source, and the item
           transform inherits the pre-injection file's OriginalItemSpec — leaving it stale would compress the
           un-injected page (the link would be missing from the .gz/.br while present in the identity page). -->
      <_ViuCssLinkUpdatedHostPageBuildCandidate Include="@(_ViuCssLinkHostPageBuild->'$(_ViuCssLinkBuildContentRoot)%(FileName)%(Extension)')"
                                                RemoveMetadata="SourceType;AssetKind;Integrity;Fingerprint" />
      <_ViuCssLinkUpdatedHostPageBuildCandidate ContentRoot="$(_ViuCssLinkBuildContentRoot)"
                                                OriginalItemSpec="%(_ViuCssLinkUpdatedHostPageBuildCandidate.Identity)" />
    </ItemGroup>

    <DefineStaticWebAssets Condition="'@(_ViuCssLinkUpdatedHostPageBuildCandidate)' != ''"
                           CandidateAssets="@(_ViuCssLinkUpdatedHostPageBuildCandidate)"
                           SourceType="Computed"
                           AssetKind="Build">
      <Output TaskParameter="Assets" ItemName="_ViuCssLinkUpdatedHostPageBuild" />
    </DefineStaticWebAssets>

    <DefineStaticWebAssetEndpoints Condition="'@(_ViuCssLinkUpdatedHostPageBuild)' != ''"
                                   CandidateAssets="@(_ViuCssLinkUpdatedHostPageBuild)"
                                   ExistingEndpoints="@(StaticWebAssetEndpoint)"
                                   ContentTypeMappings="@(StaticWebAssetContentTypeMapping)">
      <Output TaskParameter="Endpoints" ItemName="_ViuCssLinkUpdatedHostPageBuildEndpoint" />
    </DefineStaticWebAssetEndpoints>

    <FilterStaticWebAssetEndpoints Condition="'@(_ViuCssLinkHostPageBuild)' != ''"
                                   Endpoints="@(StaticWebAssetEndpoint)"
                                   Assets="@(_ViuCssLinkHostPageBuild)"
                                   Filters="">
      <Output TaskParameter="FilteredEndpoints" ItemName="_ViuCssLinkOldHostPageBuildEndpoint" />
    </FilterStaticWebAssetEndpoints>

    <ItemGroup Condition="'@(_ViuCssLinkUpdatedHostPageBuild)' != ''">
      <StaticWebAsset Remove="@(_ViuCssLinkHostPageBuild)" />
      <StaticWebAsset Include="@(_ViuCssLinkUpdatedHostPageBuild)" />
      <StaticWebAssetEndpoint Remove="@(_ViuCssLinkOldHostPageBuildEndpoint)" />
      <StaticWebAssetEndpoint Include="@(_ViuCssLinkUpdatedHostPageBuildEndpoint)" />
    </ItemGroup>
  </Target>

  <!-- PUBLISH: inject into the publish-kind host page before publish compression enumerates assets. Mirrors
       the SDK's ResolveHtmlAssetPlaceholdersPublishStaticWebAssets (AssetKind != Build → recompute as
       Publish). This is the path #167's acceptance criterion verifies against a published app. -->
  <Target Name="_ViuInjectSingleFileComponentCssLinkPublish"
          Condition="'$(ViuInjectSingleFileComponentCssLink)' == 'true' and Exists('$(ViuBundleCssTaskAssembly)')"
          BeforeTargets="ResolvePublishCompressedStaticWebAssetsConfiguration"
          DependsOnTargets="_ViuResolveSingleFileComponentCssLinkConfiguration;$(_ViuCssLinkPublishRewriteDependency)">
    <ItemGroup Condition="Exists('$(_ViuCssBundlePath)')">
      <_ViuCssLinkHostPagePublish Include="@(StaticWebAsset)"
                                  Condition="'%(Extension)' == '.html' and '%(AssetKind)' != 'Build'" />
    </ItemGroup>

    <!-- Physical FILE NAME, not %(RelativePath) — see the build target above for why the URL template is not a
         legal path; the preserved RelativePath keeps the served route unchanged. -->
    <ViuInjectCssBundleLink Condition="'@(_ViuCssLinkHostPagePublish)' != ''"
                            HostPagePath="%(_ViuCssLinkHostPagePublish.FullPath)"
                            OutputPath="$(_ViuCssLinkPublishContentRoot)%(_ViuCssLinkHostPagePublish.FileName)%(_ViuCssLinkHostPagePublish.Extension)"
                            LinkHref="$(ViuSingleFileComponentCssBundleLinkHref)"
                            BundleFileName="$(ViuSingleFileComponentCssBundleName)" />

    <ItemGroup Condition="'@(_ViuCssLinkHostPagePublish)' != ''">
      <!-- OriginalItemSpec reset to the injected file — see the build target above; it is the compression
           source path, and a stale value would compress the un-injected page. -->
      <_ViuCssLinkUpdatedHostPagePublishCandidate Include="@(_ViuCssLinkHostPagePublish->'$(_ViuCssLinkPublishContentRoot)%(FileName)%(Extension)')"
                                                  RemoveMetadata="SourceType;AssetKind;Integrity;Fingerprint" />
      <_ViuCssLinkUpdatedHostPagePublishCandidate ContentRoot="$(_ViuCssLinkPublishContentRoot)"
                                                  OriginalItemSpec="%(_ViuCssLinkUpdatedHostPagePublishCandidate.Identity)" />
    </ItemGroup>

    <DefineStaticWebAssets Condition="'@(_ViuCssLinkUpdatedHostPagePublishCandidate)' != ''"
                           CandidateAssets="@(_ViuCssLinkUpdatedHostPagePublishCandidate)"
                           SourceType="Computed"
                           AssetKind="Publish">
      <Output TaskParameter="Assets" ItemName="_ViuCssLinkUpdatedHostPagePublish" />
    </DefineStaticWebAssets>

    <DefineStaticWebAssetEndpoints Condition="'@(_ViuCssLinkUpdatedHostPagePublish)' != ''"
                                   CandidateAssets="@(_ViuCssLinkUpdatedHostPagePublish)"
                                   ExistingEndpoints="@(StaticWebAssetEndpoint)"
                                   ContentTypeMappings="@(StaticWebAssetContentTypeMapping)">
      <Output TaskParameter="Endpoints" ItemName="_ViuCssLinkUpdatedHostPagePublishEndpoint" />
    </DefineStaticWebAssetEndpoints>

    <FilterStaticWebAssetEndpoints Condition="'@(_ViuCssLinkHostPagePublish)' != ''"
                                   Endpoints="@(StaticWebAssetEndpoint)"
                                   Assets="@(_ViuCssLinkHostPagePublish)"
                                   Filters="">
      <Output TaskParameter="FilteredEndpoints" ItemName="_ViuCssLinkOldHostPagePublishEndpoint" />
    </FilterStaticWebAssetEndpoints>

    <ItemGroup Condition="'@(_ViuCssLinkUpdatedHostPagePublish)' != ''">
      <StaticWebAsset Remove="@(_ViuCssLinkHostPagePublish)" />
      <StaticWebAsset Include="@(_ViuCssLinkUpdatedHostPagePublish)" />
      <StaticWebAssetEndpoint Remove="@(_ViuCssLinkOldHostPagePublishEndpoint)" />
      <StaticWebAssetEndpoint Include="@(_ViuCssLinkUpdatedHostPagePublishEndpoint)" />
    </ItemGroup>
  </Target>
</Project>
