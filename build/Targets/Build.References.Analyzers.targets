<Project>
    <!-- Analyzer Reference By Name Only

        VuecsAnalyzerReference       - ROSLYN ANALYZER / SOURCE GENERATOR
                                            reference. Resolves against
                                            analyzers/**/*.csproj. Emits a
                                            <ProjectReference> with
                                            OutputItemType="Analyzer" +
                                            ReferenceOutputAssembly="false" so
                                            the analyzer activates at compile
                                            time (dogfood); AND adds the built
                                            analyzer DLL to the consuming
                                            library's nupkg under
                                            analyzers/dotnet/cs/ so external
                                            consumers pick it up automatically
                                            via <PackageReference>.
    -->
    <ItemGroup>
        <!-- Index analyzer projects ONCE. -->
        <_VuecsAnalyzerProject Include="$(VuecsRepositoryDirectory)analyzers\**\*.csproj" />
        <_VuecsAnalyzerProject Update="@(_VuecsAnalyzerProject)" ProjectId="%(_VuecsAnalyzerProject.Filename)" ProjectPath="%(_VuecsAnalyzerProject.Identity)" />

        <!--
            Analyzer refs. OutputItemType=Analyzer + ReferenceOutputAssembly=false
            tells the .NET SDK to load the project's output as a Roslyn analyzer
            (instead of a normal assembly reference) when the consumer builds.
            PrivateAssets=all keeps the analyzer csproj from leaking as a NuGet
            dependency of the consuming library.
        -->
        <VuecsAnalyzerReference Update="@(_VuecsAnalyzerProject->'%(ProjectId)')" ProjectPath="%(_VuecsAnalyzerProject.ProjectPath)" />
        <ProjectReference Include="@(VuecsAnalyzerReference->'%(ProjectPath)')"
                          OutputItemType="Analyzer"
                          ReferenceOutputAssembly="false"
                          PrivateAssets="all" />

        <!--
            Capture the resolved analyzer csproj paths for the pack hook below.
            We can't reuse @(VuecsAnalyzerReference) directly because it gets
            consumed (Remove'd) immediately so MSBuild's incremental graph
            cleanup is happy.
        -->
        <_VuecsAnalyzerResolved Include="@(VuecsAnalyzerReference->'%(ProjectPath)')" />
        <VuecsAnalyzerReference Remove="@(VuecsAnalyzerReference->HasMetadata('ProjectPath'))" />

        <_VuecsAnalyzerProject Remove="@(_VuecsAnalyzerProject)" />
    </ItemGroup>

    <!--
        Pack each referenced analyzer DLL into the consuming library's nupkg at
        analyzers/dotnet/cs/<Name>.dll. NuGet's built-in analyzer convention
        picks them up automatically on every consumer that adds a
        <PackageReference> to the library, so no extra wiring is needed on the
        consumer side.

        We hook TargetsForTfmSpecificContentInPackage (same extension point the
        SDK pack uses) and look up each analyzer's GetTargetPath at pack time -
        that yields the actual DLL path including the analyzer's own TFM
        (netstandard2.0), without us having to hardcode it.
    -->
    <!--
        Top-level PropertyGroup Conditions can't reference @(items) (MSB4099),
        so extend the hook unconditionally; the target's own Condition gates
        execution to projects that actually declared an analyzer reference.
    -->
    <PropertyGroup>
        <TargetsForTfmSpecificContentInPackage>$(TargetsForTfmSpecificContentInPackage);_CollectVuecsAnalyzersForPack</TargetsForTfmSpecificContentInPackage>
    </PropertyGroup>

    <Target Name="_CollectVuecsAnalyzersForPack"
            Condition="'@(_VuecsAnalyzerResolved)' != ''">
        <MSBuild Projects="@(_VuecsAnalyzerResolved)"
                 Targets="GetTargetPath"
                 Properties="Configuration=$(Configuration)"
                 RemoveProperties="OutDir;OutputPath;IntermediateOutputPath;TargetFramework;TargetFrameworks;RuntimeIdentifier">
            <Output TaskParameter="TargetOutputs" ItemName="_VuecsAnalyzerDll" />
        </MSBuild>
        <ItemGroup>
            <TfmSpecificPackageFile Include="@(_VuecsAnalyzerDll)">
                <PackagePath>analyzers/dotnet/cs</PackagePath>
            </TfmSpecificPackageFile>
        </ItemGroup>

        <!--
            An analyzer may ship consumer-facing MSBuild logic in a sibling build/ folder next to its src/
            (e.g. Assimalign.Vue.Syntax.Generators flows .viu files in as AdditionalFiles). Pack those
            props/targets into the consuming library's nupkg under buildTransitive/ so the packaged
            consumer picks them up. Dormant for analyzers with no build/ folder (the glob matches nothing).
        -->
        <ItemGroup>
            <_VuecsAnalyzerBuildDirectory Include="@(_VuecsAnalyzerResolved->'%(RootDir)%(Directory)..\build')" />
        </ItemGroup>
        <ItemGroup>
            <_VuecsAnalyzerBuildFile Include="%(_VuecsAnalyzerBuildDirectory.Identity)\**\*.props;%(_VuecsAnalyzerBuildDirectory.Identity)\**\*.targets" />
            <!-- NuGet auto-imports only buildTransitive/<PackageId>.props|targets, so the files are
                 packed under the CONSUMING package's id (also silencing NU5129), never under the
                 analyzer's own file name. -->
            <TfmSpecificPackageFile Include="@(_VuecsAnalyzerBuildFile)">
                <PackagePath>buildTransitive\$(PackageId)%(Extension)</PackagePath>
            </TfmSpecificPackageFile>
        </ItemGroup>
    </Target>
    <!--
        A generator consumed by ProjectReference (OutputItemType=Analyzer) surfaces only its own DLL to
        the consumer's compiler, but Roslyn resolves a generator's dependencies exclusively among the
        registered analyzer paths - so a generator with project-reference dependencies must append those
        outputs to its own GetTargetPath result for every consumer to load the full closure. Analyzer
        csprojs opt in with <VuecsAnalyzerBundlesProjectReferenceOutputs>true</...>.
    -->
    <PropertyGroup Condition="'$(VuecsAnalyzerBundlesProjectReferenceOutputs)' == 'true'">
        <GetTargetPathDependsOn>$(GetTargetPathDependsOn);_VuecsAppendAnalyzerProjectReferenceOutputs</GetTargetPathDependsOn>
    </PropertyGroup>
    <Target Name="_VuecsAppendAnalyzerProjectReferenceOutputs"
            Condition="'$(VuecsAnalyzerBundlesProjectReferenceOutputs)' == 'true'"
            DependsOnTargets="ResolveProjectReferences">
        <ItemGroup>
            <TargetPathWithTargetPlatformMoniker Include="@(_ResolvedProjectReferencePaths)" IncludeRuntimeDependency="false" />
        </ItemGroup>
    </Target>

    <!--
        In-repo dogfooding seam for the .viu generator: packaged consumers receive its MSBuild wiring
        (the **/*.viu AdditionalFiles glob and CompilerVisibleProperty declarations) through
        buildTransitive, but a VuecsAnalyzerReference inside this repo would not - imports evaluate
        before items exist, so the wiring is opted into with a property instead of inferred from the
        reference: set <VuecsUseSingleFileComponents>true</...> alongside the analyzer reference.
    -->
    <Import Project="$(VuecsRepositoryDirectory)analyzers\Assimalign.Vue.Syntax.Generators\build\Assimalign.Vue.Syntax.Generators.props"
            Condition="'$(VuecsUseSingleFileComponents)' == 'true' and Exists('$(VuecsRepositoryDirectory)analyzers\Assimalign.Vue.Syntax.Generators\build\Assimalign.Vue.Syntax.Generators.props')" />
    <Import Project="$(VuecsRepositoryDirectory)analyzers\Assimalign.Vue.Syntax.Generators\build\Assimalign.Vue.Syntax.Generators.targets"
            Condition="'$(VuecsUseSingleFileComponents)' == 'true' and Exists('$(VuecsRepositoryDirectory)analyzers\Assimalign.Vue.Syntax.Generators\build\Assimalign.Vue.Syntax.Generators.targets')" />
</Project>