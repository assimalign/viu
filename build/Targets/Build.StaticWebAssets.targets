<Project>
    <!--
        Static web assets for project-referenced Viu libraries.

        Libraries that ship a JavaScript half (Assimalign.Viu.RuntimeDom's interop bridge)
        own it under src/wwwroot/ and stay on the plain Microsoft.NET.Sdk: the WebAssembly
        dev host (WasmAppHost, the non-Blazor "WebAssembly Browser App" host) cannot serve a
        referenced Razor-SDK class library's _content assets - measured on .NET SDK 10.0.10,
        it stops serving the app entirely when such a reference exists, and its only dev
        serving pattern maps the app's SOURCE wwwroot ([V01.01.04.01] decision, see
        libraries/Assimalign.Viu.RuntimeDom/docs/DESIGN.md).

        This target therefore copies every direct project-referenced library's wwwroot/**
        into the consuming WebAssembly app's SOURCE wwwroot under _content/<AssemblyName>/...
        (a gitignored build artifact), which the dev host serves via its wwwroot pattern and
        publish picks up with the rest of wwwroot. The /_content/<id>/ URL shape matches the
        Razor-SDK convention, so JSHost.ImportAsync call sites keep the standard path when
        NuGet packaging later ships the same files as real static web assets.

        Limitation: only DIRECT ProjectReference entries flow (the example app references
        Assimalign.Viu.RuntimeDom directly); extend to transitive references if a library
        ever consumes another library's assets.
    -->
    <Target Name="ViuFlowReferencedLibraryWebAssets"
            BeforeTargets="ResolveProjectStaticWebAssets;AssignTargetPaths"
            Condition="'$(UsingMicrosoftNETSdkWebAssembly)' == 'true'">
        <ItemGroup>
            <_ViuLibraryWebAsset Include="%(ProjectReference.RootDir)%(ProjectReference.Directory)wwwroot\**\*"
                                   ReferenceName="%(ProjectReference.Filename)" />
        </ItemGroup>
        <Copy SourceFiles="@(_ViuLibraryWebAsset)"
              DestinationFiles="@(_ViuLibraryWebAsset->'$(MSBuildProjectDirectory)\wwwroot\_content\%(ReferenceName)\%(RecursiveDir)%(Filename)%(Extension)')"
              SkipUnchangedFiles="true" />
        <ItemGroup>
            <_ViuLibraryWebAsset Remove="@(_ViuLibraryWebAsset)" />
        </ItemGroup>
    </Target>
</Project>
