<Project>

    <!-- Viu Specific Build Flags for all all projects in the repository -->
	<PropertyGroup>
		<ViuRepositoryDirectory>$([System.IO.Path]::GetFullPath('$(MSBuildThisFileDirectory)\..\..'))\</ViuRepositoryDirectory>
		<ViuOutputPath>$(ViuRepositoryDirectory)_out</ViuOutputPath>
		<ViuOutputPathForSdk>$(ViuOutputPath)\dotnet\sdk</ViuOutputPathForSdk>
		<ViuOutputPathForCli>$(ViuOutputPath)\dotnet</ViuOutputPathForCli>
		<ViuOutputPathForPacks>$(ViuOutputPath)\dotnet\packs</ViuOutputPathForPacks>
		<ViuOutputPathForLibraries>$(ViuOutputPath)\packages</ViuOutputPathForLibraries>
		<ViuOutputPathForDevScripts>$(ViuRepositoryDirectory)scripts\modules</ViuOutputPathForDevScripts>
	</PropertyGroup>

	<!-- TODO: Need to verify if this is the correct way for generating the Intermediate path  -->
	<PropertyGroup>
        <_ViuIntermediateOutputPath Condition=" '$(PlatformName)' == 'AnyCPU' ">$(MSBuildProjectDirectory)\obj$(IntermediateOutputPath)$(Configuration)\</_ViuIntermediateOutputPath>
        <_ViuIntermediateOutputPath Condition=" '$(PlatformName)' != 'AnyCPU' ">$(MSBuildProjectDirectory)\obj$(IntermediateOutputPath)$(PlatformName)\$(Configuration)\</_ViuIntermediateOutputPath>
    </PropertyGroup>

    <!-- Language specific Configuration -->
	<PropertyGroup>
		<Nullable>enable</Nullable>
		<LangVersion>preview</LangVersion>
		<EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>
	</PropertyGroup>

	<!-- Viu Build Properties -->
	<PropertyGroup Condition="'$(Configuration)' == 'Release'">
		<DebugType>none</DebugType>
	</PropertyGroup>
	
	<ItemGroup Condition="Exists('$(ViuRepositoryDirectory).editorconfig')">
		<AdditionalFiles Include="$(ViuRepositoryDirectory).editorconfig" />
	</ItemGroup>
</Project>