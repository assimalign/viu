<Project>

    <!-- Vuecs Specific Build Flags for all all projects in the repository -->
	<PropertyGroup>
		<VuecsRepositoryDirectory>$([System.IO.Path]::GetFullPath('$(MSBuildThisFileDirectory)\..\..'))\</VuecsRepositoryDirectory>
		<VuecsOutputPath>$(VuecsRepositoryDirectory)_out</VuecsOutputPath>
		<VuecsOutputPathForSdk>$(VuecsOutputPath)\dotnet\sdk</VuecsOutputPathForSdk>
		<VuecsOutputPathForCli>$(VuecsOutputPath)\dotnet</VuecsOutputPathForCli>
		<VuecsOutputPathForPacks>$(VuecsOutputPath)\dotnet\packs</VuecsOutputPathForPacks>
		<VuecsOutputPathForLibraries>$(VuecsOutputPath)\packages</VuecsOutputPathForLibraries>
		<VuecsOutputPathForDevScripts>$(VuecsRepositoryDirectory)scripts\modules</VuecsOutputPathForDevScripts>
	</PropertyGroup>

	<!-- TODO: Need to verify if this is the correct way for generating the Intermediate path  -->
	<PropertyGroup>
        <_VuecsIntermediateOutputPath Condition=" '$(PlatformName)' == 'AnyCPU' ">$(MSBuildProjectDirectory)\obj$(IntermediateOutputPath)$(Configuration)\</_VuecsIntermediateOutputPath>
        <_VuecsIntermediateOutputPath Condition=" '$(PlatformName)' != 'AnyCPU' ">$(MSBuildProjectDirectory)\obj$(IntermediateOutputPath)$(PlatformName)\$(Configuration)\</_VuecsIntermediateOutputPath>
    </PropertyGroup>

    <!-- Language specific Configuration -->
	<PropertyGroup>
		<Nullable>enable</Nullable>
		<LangVersion>preview</LangVersion>
		<EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>
	</PropertyGroup>

	<!-- Vuecs Build Properties -->
	<PropertyGroup Condition="'$(Configuration)' == 'Release'">
		<DebugType>none</DebugType>
	</PropertyGroup>
	
	<ItemGroup Condition="Exists('$(VuecsRepositoryDirectory).editorconfig')">
		<AdditionalFiles Include="$(VuecsRepositoryDirectory).editorconfig" />
	</ItemGroup>
</Project>