<Project>
    <!--
        Project Reference By Name Only.

        Lets a library/example/analyzer csproj reference another project by its
        assembly name instead of by relative csproj path. Resolution walks
        .redesign/ once, matches each item's Include to the csproj whose filename
        matches, and emits a regular <ProjectReference Include="<resolved-path>" />
        with the appropriate per-flavour metadata.

        Two flavours:

          ViuProjectReference         - PUBLIC code reference. Resulting
                                            <ProjectReference> has default
                                            semantics: compiled against,
                                            CopyLocal'd into bin/, AND appears
                                            as a <dependency> in this library's
                                            .nupkg .nuspec (flows to consumers).

                                            Usage (by assembly name only):
                                              <ViuProjectReference Include="Assimalign.Viu.Shared" />

          ViuPrivateProjectReference  - PRIVATE code reference. Same compile
                                            + CopyLocal behaviour, but the
                                            resulting <ProjectReference> carries
                                            PrivateAssets="all", which suppresses
                                            the <dependency> entry in the .nuspec.
                                            Consumers of this library's .nupkg
                                            never learn about the target. Use for
                                            "this library needs X as an internal
                                            implementation detail but should not
                                            expose X to its consumers".
    -->
    <ItemGroup>
        <!-- Index code projects ONCE. Analyzer/generator projects are indexed too so a test (or other
             code project) can take a normal compile reference to one by assembly name — the analyzer
             SDK's OutputItemType="Analyzer" reference (ViuAnalyzerReference) cannot be compiled
             against, so a generator's own snapshot tests resolve it as a ViuPrivateProjectReference. -->
        <_ViuProject Include="$(ViuRepositoryDirectory)libraries\**\*.csproj" />
        <_ViuProject Include="$(ViuRepositoryDirectory)analyzers\**\*.csproj" />
        <!-- Benchmarks are a first-class non-shipping code area ([V01.01.11.04], #88), like analyzers:
             indexing them lets the benchmark test project take a by-name compile reference to the
             benchmark app, and lets both resolve the runtime libraries they measure. -->
        <_ViuProject Include="$(ViuRepositoryDirectory)benchmarks\**\*.csproj" />
        <_ViuProject Update="@(_ViuProject)" ProjectId="%(_ViuProject.Filename)" ProjectPath="%(_ViuProject.Identity)" />

        <!-- Public refs -->
        <ViuProjectReference Update="@(_ViuProject->'%(ProjectId)')" ProjectPath="%(_ViuProject.ProjectPath)" />
        <ProjectReference Include="@(ViuProjectReference->'%(ProjectPath)')" />
        <ViuProjectReference Remove="@(ViuProjectReference->HasMetadata('ProjectPath'))" />

        <!-- Private refs: PrivateAssets='all' suppresses .nuspec <dependency> flow. -->
        <ViuPrivateProjectReference Update="@(_ViuProject->'%(ProjectId)')" ProjectPath="%(_ViuProject.ProjectPath)" />
        <ProjectReference Include="@(ViuPrivateProjectReference->'%(ProjectPath)')" PrivateAssets="all" />
        <ViuPrivateProjectReference Remove="@(ViuPrivateProjectReference->HasMetadata('ProjectPath'))" />

        <_ViuProject Remove="@(_ViuProject)" />
    </ItemGroup>
</Project>
